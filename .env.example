# URL publique du site
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Stripe - Clés API (tableau de bord Stripe)
STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Prix du service en centimes d'euros (3900 = 39,00€)
SERVICE_PRICE_CENTS=3900

# Anthropic - Agent IA
ANTHROPIC_API_KEY=sk-ant-...

# Email (SMTP) - pour les notifications clients
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=votre@email.com
SMTP_PASS=votre_mot_de_passe
SMTP_FROM="ETA UK Service <noreply@eta-uk.fr>"

# Carte bancaire société pour payer les frais gouvernementaux UK (£10/personne)
# ATTENTION : stocker de manière sécurisée, ne jamais committer
COMPANY_CARD_NUMBER=4111111111111111
COMPANY_CARD_EXPIRY=12/28
COMPANY_CARD_CVC=123
COMPANY_CARD_NAME=ETA UK SERVICE SAS
